@startuml UC_03_Forgot_Password
title UC-03: Forgot Password

|User|
start
:(1) Open the Forgot Password page;
:(2) Enter email;
:(3) Submit email;

|System|
:(4) Validate email;
if (Email valid?) then (Yes)
  :(5) Look up the account;
  if (Local auth account?) then (Yes)
    :(6) Create OTP and reset request;
  else (No)
    :(7) Return error message;
    stop
  endif
else (No)
  :(8) Return error message;
  stop
endif

|Third-party Email Service|
:(9) Deliver OTP email;

|User|
:(10) Enter received OTP;
:(11) Submit OTP;

|System|
:(12) Verify OTP and mark reset request as verified;
if (OTP valid?) then (Yes)
  :(13) Generate reset token;
else (No)
  :(14) Return error message;
  stop
endif

|User|
:(15) Enter new password and confirm password;
:(16) Submit password reset;

|System|
:(17) Validate new password;
if (Password valid?) then (Yes)
  :(18) Hash new password and update account;
  :(19) Delete reset request and return success;
else (No)
  :(20) Return error message;
endif

stop
@enduml
