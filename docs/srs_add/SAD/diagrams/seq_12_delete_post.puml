@startuml seq_12_delete_post
title Sequence Diagram: UC-12 Delete Post

actor User
participant "User Web" as Frontend
participant "Post Controller" as Controller
participant "Post Service" as Service
participant "Post Repo" as PostRepo
participant "User Repo" as UserRepo

User -> Frontend: (1.1) Open post menu
User -> Frontend: (2.1) Choose Delete post
User -> Frontend: (3.1) Confirm deletion
Frontend -> Controller: (3.2) DELETE /api/posts/{id}
Controller -> Service: (4.1) Delete post request
Service -> PostRepo: (4.2) Load post record
PostRepo --> Service: (4.3) Post data
Service -> Service: (5.1) Verify delete permission

alt User is authorized
    Service -> PostRepo: (6.1) Soft delete post
    PostRepo --> Service: (6.2) Post marked deleted
    
    alt User is the Author
        Service -> UserRepo: (7.1) Decrease user post count
        UserRepo --> Service: (7.2) Count updated
    end
    
    Service --> Controller: (8.1) Delete success response
    Controller --> Frontend: (8.2) 200 OK
    Frontend --> User: (8.3) Remove post from UI
else Not authorized
    Service --> Controller: (9.1) Forbidden error
    Controller --> Frontend: (9.2) 403 Forbidden
    Frontend --> User: (9.3) Show error message
end
@enduml
